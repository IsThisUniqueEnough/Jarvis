JarvisCrypt = {}
JarvisCrypt.toHex = function(num)
    hexChars = "0123456789ABCDEF"
    return hexChars[floor(num / 16)] + hexChars[num % 16]
end function

JarvisCrypt.fromHex = function(hexStr)
    hexChars = "0123456789ABCDEF"
    val1 = hexChars.indexOf(hexStr[0])
    val2 = hexChars.indexOf(hexStr[1])
    return (val1 * 16) + val2
end function

JarvisCrypt.encrypt = function(plainText, key)
    if plainText.len == 0 then return ""
    if key.len == 0 then return plainText
    
    salt = floor(rnd * 256)
    cipherHex = JarvisCrypt.toHex(salt)
    prevCipherCode = salt
    
    for i in range(0, plainText.len - 1)
        pCode = plainText[i].code
        kCode = key[i % key.len].code
        shifted = (pCode + kCode + prevCipherCode) % 256
        cipherHex = cipherHex + JarvisCrypt.toHex(shifted)
        prevCipherCode = shifted
    end for
    return cipherHex
end function

JarvisCrypt.decrypt = function(cipherHex, key)
    if cipherHex.len <= 2 then return "" 
    if key.len == 0 or cipherHex.len % 2 != 0 then return ""
    
    prevCipherCode = JarvisCrypt.fromHex(cipherHex[0:2])
    plainText = ""
    i = 2 
    charIndex = 0 
    
    while i < cipherHex.len
        hexByte = cipherHex[i] + cipherHex[i+1]
        cCode = JarvisCrypt.fromHex(hexByte)
        kCode = key[charIndex % key.len].code
        shifted = (cCode - kCode - prevCipherCode) % 256
        while shifted < 0 
            shifted = shifted + 256
        end while
        plainText = plainText + char(shifted)
        prevCipherCode = cCode
        i = i + 2
        charIndex = charIndex + 1
    end while
    return plainText
end function

